<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvItemName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Item Name"
                android:textColor="#2E3192"
                android:textStyle="bold"
                android:textSize="13sp"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TRX: - | Store: -"
                android:textColor="#666666"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reason: -"
                android:textColor="#444444"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvQty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Qty: 0"
                android:textColor="#F5333F"
                android:textStyle="bold"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00"
                android:textColor="#333333"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btnReturnToStore"
            android:layout_width="130dp"
            android:layout_height="36dp"
            android:text="Return"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00A651" />

        <Button
            android:id="@+id/btnDispose"
            android:layout_width="110dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:text="Dispose"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#F5333F" />
    </LinearLayout>

</LinearLayout>