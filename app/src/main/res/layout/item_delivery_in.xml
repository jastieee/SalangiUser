<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="6dp"
    android:layout_marginTop="4dp"
    android:layout_marginEnd="6dp"
    android:layout_marginBottom="4dp"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvProductCode"
            android:layout_width="425dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="ITEM001"
            android:textColor="#2E3192"
            android:textSize="11sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnRemove"
            android:layout_width="66dp"
            android:layout_height="32dp"
            android:backgroundTint="#F5333F"
            android:text="Delete"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Sample item description"
        android:textColor="#333333"
        android:textSize="10sp"
        android:maxLines="2"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tvQty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Qty: 1"
        android:textColor="#222222"
        android:textSize="10sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTotalCost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Total: ₱0.00"
        android:textColor="#F5333F"
        android:textSize="10sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvUnitCost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Cost/Unit: ₱0.00"
        android:textColor="#00A651"
        android:textSize="10sp"
        android:textStyle="bold" />

</LinearLayout>