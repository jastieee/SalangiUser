<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F4F4">

    <!-- ══════════════════════════════════════════════════════ HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#2E3192"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="60dp"
            android:layout_height="38dp"
            android:text="←"
            android:textColor="#2E3192"
            android:textStyle="bold"
            android:backgroundTint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Refund Items"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center" />

        <Button
            android:id="@+id/btnProcessRefund"
            android:layout_width="100dp"
            android:layout_height="38dp"
            android:text="Process"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#F5333F"
            android:enabled="false" />
    </LinearLayout>

    <!-- ════════════════════════════════════ SCROLLABLE BODY -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════════════════════════════════════ SEARCH CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="10dp"
                android:layout_margin="8dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transaction Number"
                    android:textColor="#2E3192"
                    android:textStyle="bold"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <EditText
                        android:id="@+id/etTransactionNo"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:background="@drawable/input_border"
                        android:hint="TXN-000001"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:textSize="11sp"
                        android:inputType="text"
                        android:imeOptions="actionSearch"
                        android:singleLine="true" />

                    <Button
                        android:id="@+id/btnSearch"
                        android:layout_width="80dp"
                        android:layout_height="38dp"
                        android:layout_marginStart="6dp"
                        android:text="Search"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2E3192"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTransactionInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#555555"
                    android:layout_marginTop="6dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- ══════════════════════════════════════ REFUND TYPE ROW -->
            <LinearLayout
                android:id="@+id/layoutRefundType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFF9E1"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Type:"
                    android:textColor="#7A5B00"
                    android:textStyle="bold"
                    android:textSize="11sp" />

                <RadioGroup
                    android:id="@+id/rgRefundType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="10dp">

                    <RadioButton
                        android:id="@+id/rbFullRefund"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full"
                        android:textSize="11sp"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/rbPartialRefund"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Partial"
                        android:textSize="11sp"
                        android:layout_marginStart="12dp" />
                </RadioGroup>

                <TextView
                    android:id="@+id/tvRefundTotal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Refund Amount: ₱0.00"
                    android:textColor="#F5333F"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:gravity="end" />
            </LinearLayout>

            <!-- ══════════════════════════════════════ TABLE HEADER -->
            <LinearLayout
                android:id="@+id/layoutTableHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2E3192"
                android:orientation="horizontal"
                android:padding="6dp"
                android:layout_marginTop="6dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:text="Item"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Code"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Price"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:gravity="end" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Qty"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Refund"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Amount"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:gravity="end" />
            </LinearLayout>

            <!-- ══════════════════════════════════════ ITEMS LIST
                 Non-scrollable ListView inside ScrollView —
                 use a fixed height or wrap in a ListViewCompat helper.
                 We set it wrap_content; the outer ScrollView handles scroll. -->
            <ListView
                android:id="@+id/listRefundItems"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:divider="#E0E0E0"
                android:dividerHeight="1dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:visibility="gone" />

            <!-- bottom padding -->
            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>