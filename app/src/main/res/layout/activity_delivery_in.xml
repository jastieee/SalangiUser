<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6F8">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="#2E3192">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:backgroundTint="#FFFFFF"
            android:text="←"
            android:textColor="#253AA5"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Delivery In"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="72dp"
            android:layout_height="50dp"
            android:backgroundTint="#F5333F"
            android:text="Save"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Form fields -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="#FFFFFF">

        <!-- Row 1: Supplier -->
        <AutoCompleteTextView
            android:id="@+id/actSupplier"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="Search / Select Supplier"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:singleLine="true"
            android:textSize="10sp"
            android:imeOptions="actionNext"
            android:background="@android:drawable/edit_text" />

        <!-- Row 2: PO Number + Auto checkbox side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etPoNumber"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:hint="PO Number (optional)"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:singleLine="true"
                android:textSize="10sp"
                android:imeOptions="actionNext"
                android:nextFocusForward="@id/etInvoiceNo" />

            <CheckBox
                android:id="@+id/cbAutoPoNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Auto PO"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Row 3: SI and DR side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <EditText
                android:id="@+id/etInvoiceNo"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:hint="Sales Invoice No."
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:singleLine="true"
                android:textSize="10sp"
                android:imeOptions="actionDone"
                android:nextFocusForward="@id/etDrNo" />

            <View
                android:layout_width="6dp"
                android:layout_height="match_parent" />

            <EditText
                android:id="@+id/etDrNo"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:hint="DR Number"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:singleLine="true"
                android:textSize="10sp"
                android:imeOptions="actionDone" />
        </LinearLayout>

        <!-- Row 4: Warehouse -->
        <Spinner
            android:id="@+id/spinnerWarehouse"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <!-- Hidden barcode scanner field -->
    <EditText
        android:id="@+id/etBarcode"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0"
        android:background="@null"
        android:cursorVisible="false"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:imeOptions="actionNone"
        android:inputType="text" />

    <ListView
        android:id="@+id/listDeliveryItems"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="4dp" />

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:background="#2E3192">

        <TextView
            android:id="@+id/tvItemCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Items: 0"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvTotalAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₱0.00"
            android:textColor="#F9C80E"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>