<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="52dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="#FFFFFF"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <TextView
        android:id="@+id/tvTransferNo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:text="TRF-0001"
        android:textSize="10sp"
        android:textColor="#2E3192"
        android:textStyle="bold"
        android:singleLine="true"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tvWarehouse"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="3"
        android:text="Main Warehouse"
        android:textSize="10sp"
        android:textColor="#333333"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

    <TextView
        android:id="@+id/tvStore"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="3"
        android:text="Store A"
        android:textSize="10sp"
        android:textColor="#333333"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:text="2026-04-20"
        android:textSize="10sp"
        android:textColor="#666666"
        android:singleLine="true" />

    <TextView
        android:id="@+id/tvItemCount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="5"
        android:textSize="11sp"
        android:textColor="#333333"
        android:textStyle="bold"
        android:gravity="center"
        android:singleLine="true" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:text="Pending"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="#F9C80E"
        android:gravity="center"
        android:singleLine="true" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnConfirm"
        android:layout_width="62dp"
        android:layout_height="36dp"
        android:layout_marginStart="6dp"
        android:text="Confirm"
        android:textAllCaps="false"
        android:textSize="9sp"
        android:textStyle="bold"
        android:backgroundTint="#00A651"
        android:textColor="#FFFFFF"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:minWidth="0dp"
        android:focusable="false"
        android:focusableInTouchMode="false" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnDeny"
        android:layout_width="54dp"
        android:layout_height="36dp"
        android:layout_marginStart="4dp"
        android:text="Deny"
        android:textAllCaps="false"
        android:textSize="9sp"
        android:textStyle="bold"
        android:backgroundTint="#C62828"
        android:textColor="#FFFFFF"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:minWidth="0dp"
        android:focusable="false"
        android:focusableInTouchMode="false" />

</LinearLayout>