<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F4F4">

    <!-- Compact Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:background="#2E3192">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome, User"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="April 17, 2026 4:00 PM"
                android:textColor="#D8DEFF"
                android:textSize="9sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="68dp"
            android:layout_height="32dp"
            android:backgroundTint="#F5333F"
            android:text="Logout"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Compact Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="6dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dashboard"
            android:textColor="#2E3192"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose a module"
            android:textColor="#666666"
            android:textSize="9sp" />
    </LinearLayout>

    <!-- Scrollable Grid -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:paddingStart="6dp"
            android:paddingTop="2dp"
            android:paddingEnd="6dp"
            android:paddingBottom="10dp">

            <!-- Warehouse Inventory -->
            <LinearLayout
                android:id="@+id/cardWarehouseInventory"
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/card_bg_blue"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏭"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="Warehouse Inventory"
                    android:textColor="#2E3192"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Store Inventory -->
            <LinearLayout
                android:id="@+id/cardStoreInventory"
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/card_bg_yellow"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏪"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="Store Inventory"
                    android:textColor="#7A5B00"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Checkout -->
            <LinearLayout
                android:id="@+id/cardScanItems"
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/card_bg_green"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📷"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="Checkout Items"
                    android:textColor="#006B34"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Stock Transfer -->
            <LinearLayout
                android:id="@+id/cardStockTransfers"
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/card_bg_red"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚚"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="Stock Transfers"
                    android:textColor="#A32028"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Delivery -->
            <LinearLayout
                android:id="@+id/cardDeliveryIn"
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/card_bg_blue"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📥"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="Delivery In"
                    android:textColor="#2E3192"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Refund Items -->
            <LinearLayout
                android:id="@+id/cardRefundItems"
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/card_bg_yellow"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↩️"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="Refund Items"
                    android:textColor="#7A5B00"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Transfer Confirm -->
            <LinearLayout
                android:id="@+id/cardTransferConfirmations"
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/card_bg_green"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="Transfer Confirm"
                    android:textColor="#006B34"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Refund Decisions -->
            <LinearLayout
                android:id="@+id/cardRefundDecisions"
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/card_bg_red"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="Refund Decisions"
                    android:textColor="#A32028"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Bad Order -->
            <LinearLayout
                android:id="@+id/cardBadOrder"
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/card_bg_purple"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="Bad Order"
                    android:textColor="#6A1B9A"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Price Verifier -->
            <LinearLayout
                android:id="@+id/cardPriceVerifier"
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/card_bg_purple"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏷️"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="Price Verifier"
                    android:textColor="#6A1B9A"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </GridLayout>

    </ScrollView>

</LinearLayout>