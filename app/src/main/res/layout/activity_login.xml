<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F4F4"
    android:padding="20dp">

    <!-- Top spacing -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="24dp" />

    <!-- Logo card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#FFFFFF"
        android:padding="16dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/salangi"
            android:contentDescription="Three E's Toys and Candy Store Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Welcome Back"
            android:textColor="#2E3192"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Form card -->

    <!-- Bottom accent -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Username"
            android:textColor="#2E3192"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/input_border"
            android:hint="Enter username"
            android:inputType="text"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:singleLine="true"
            android:textColor="#222222"
            android:textColorHint="#888888"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Password"
            android:textColor="#2E3192"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/input_border"
            android:hint="Enter password"
            android:inputType="textPassword"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:singleLine="true"
            android:textColor="#222222"
            android:textColorHint="#888888"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnSignIn"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#00A651"
            android:text="Sign In"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#FFF1F1"
            android:padding="10dp"
            android:textColor="#F5333F"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="horizontal">

        <View
            android:layout_width="40dp"
            android:layout_height="6dp"
            android:background="#F5333F" />

        <View
            android:layout_width="40dp"
            android:layout_height="6dp"
            android:layout_marginStart="6dp"
            android:background="#F9C80E" />

        <View
            android:layout_width="40dp"
            android:layout_height="6dp"
            android:layout_marginStart="6dp"
            android:background="#00A651" />

        <View
            android:layout_width="40dp"
            android:layout_height="6dp"
            android:layout_marginStart="6dp"
            android:background="#2E3192" />
    </LinearLayout>

</LinearLayout>