<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F4F4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:background="#2E3192">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="60dp"
            android:layout_height="38dp"
            android:text="←"
            android:textStyle="bold"
            android:textColor="#2E3192"
            android:backgroundTint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Refund Decisions"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center" />

        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="80dp"
            android:layout_height="38dp"
            android:text="Refresh"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="10sp"
            android:backgroundTint="#00A651" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="10dp"
        android:layout_margin="8dp"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tvPendingCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pending: 0"
            android:textColor="#2E3192"
            android:textStyle="bold"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose whether each refunded item will be returned to store stock or disposed."
            android:textColor="#666666"
            android:textSize="10sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <ListView
        android:id="@+id/listRefundDecisions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</LinearLayout>