<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EEF1FF"
        android:padding="10dp">

        <TextView
            android:id="@+id/tvDialogCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ITEM001"
            android:textColor="#2E3192"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDialogDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sample item"
            android:textColor="#333333"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvDialogStock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Available Stock: 0"
            android:textColor="#00A651"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quantity"
        android:textColor="#2E3192"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginTop="14dp" />

    <EditText
        android:id="@+id/etDialogQty"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/input_border"
        android:gravity="center"
        android:hint="Enter quantity"
        android:inputType="numberDecimal"
        android:textColor="#000000"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reason / Remarks"
        android:textColor="#2E3192"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginTop="14dp" />

    <EditText
        android:id="@+id/etDialogReason"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/input_border"
        android:gravity="top|start"
        android:hint="Example: Damaged, expired, pull-out, supplier return"
        android:inputType="textMultiLine"
        android:padding="8dp"
        android:textColor="#000000"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFF4F4"
        android:padding="10dp"
        android:layout_marginTop="14dp">

        <TextView
            android:id="@+id/tvDialogSubtotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Subtotal: ₱0.00"
            android:textColor="#F5333F"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>